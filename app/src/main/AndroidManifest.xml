<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- NFC -->
    <uses-permission android:name="android.permission.NFC" />

    <!--
        WRITE_EXTERNAL_STORAGE solo se necesita en Android ≤ 9 (API 28)
        para guardar la foto del DG2 en galería. En API 29+ se usa
        MediaStore sin permiso adicional (ya está en ResultActivity).
    -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!--
        android:required="true" → la app solo aparece en Google Play
        en dispositivos con NFC. Cámbialo a false si quieres distribución amplia
        y gestionas la ausencia de NFC por código (ya lo hace MainActivity).
    -->
    <uses-feature android:name="android.hardware.nfc" android:required="true" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        tools:replace="android:theme"
        android:theme="@style/Theme.DetectorNFC">

        <!-- ── MainActivity ───────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── NFCScanActivity ────────────────────────────────────── -->
        <!--
            Usa NfcAdapter.enableReaderMode() en onResume/onPause, por lo que
            NO necesita intent-filter de NFC para funcionar en primer plano.

            El bloque TECH_DISCOVERED sí es útil si en el futuro quieres que el
            sistema abra la app directamente al acercar un documento (background).
            Está comentado; descoméntalo si lo necesitas.
        -->
        <activity
            android:name=".NFCScanActivity"
            android:exported="false"
            android:label="Escanear documento"
            android:launchMode="singleTop">

            <!--
            <intent-filter>
                <action android:name="android.nfc.action.TECH_DISCOVERED" />
            </intent-filter>
            <meta-data
                android:name="android.nfc.action.TECH_DISCOVERED"
                android:resource="@xml/nfc_tech_filter" />
            -->
        </activity>

        <!-- ── ResultActivity ─────────────────────────────────────── -->
        <activity
            android:name=".ResultActivity"
            android:exported="false"
            android:label="Resultados" />

        <!-- ── FileProvider (compartir JSON / foto DG2) ───────────── -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/filepaths" />
        </provider>

    </application>

</manifest>